# Server (apps/server)
PORT=3002

# Web (apps/web) — optional; dev defaults to http://127.0.0.1:3002
# Production on Vercel uses same-origin /api/* serverless routes (see apps/web/api).
# Set only if the API runs on a different host:
# VITE_API_URL=https://your-api-host.example.com
# VITE_API_PORT=3002
# Chat: Anthropic preferred if set, else OpenAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: enable live LinkedIn scrape (default: mock data only)
ENABLE_LIVE_SCRAPE=false

# Finder: WestJet uses data/westjet-search-sample.json unless HERMES_FINDER_LIVE=1
# HERMES_FINDER_LIVE=1
# HERMES_FINDER_FAST=0  # force full company web research before people search (~90s)
HERMES_FINDER_CACHE=1
HERMES_FINDER_CACHE_TTL_DAYS=14
HERMES_FINDER_WEB_SEARCH_USES=3
HERMES_FINDER_STEPS=5
HERMES_FINDER_RETRY=0
# Server-side cap for live AI finder (ms). Client waits ~150s. Vercel defaults to 50s.
# HERMES_FINDER_TIMEOUT_MS=120000
